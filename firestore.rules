rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Permitir lectura y escritura solo si los datos tienen el formato correcto
      // (Esto es una seguridad mínima antes de poner autenticación de usuario)
      allow read: if true;
      allow write: if request.resource.data.amount is string || request.resource.data.amount is number;
    }
  }
}